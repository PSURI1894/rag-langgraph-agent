# Required for generation and LLM-judge evals (ingestion/retrieval run without it)
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# GENERATION_MODEL=claude-opus-4-8
# JUDGE_MODEL=claude-opus-4-8
# RETRIEVAL_K=4

# Retrieval strategy. Default is fast/light dense search; the high-accuracy mode
# is hybrid (BM25 + dense) with a local cross-encoder reranker (downloads an
# ~80MB ONNX model on first use, still no API key).
# RETRIEVAL_MODE=hybrid
# USE_RERANKER=true
# FETCH_K=12
# RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# Optional: LangSmith tracing (https://smith.langchain.com)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=rag-langgraph-agent
