# Required for generation and LLM-judge evals (ingestion/retrieval run without it)
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# GENERATION_MODEL=claude-opus-4-8
# JUDGE_MODEL=claude-opus-4-8
# RETRIEVAL_K=4

# Optional: LangSmith tracing (https://smith.langchain.com)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=rag-langgraph-agent
